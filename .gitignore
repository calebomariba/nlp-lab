# ============================================================
# NLP / ML PROJECT SPECIFIC
# ============================================================

# ── Large Data Files ─────────────────────────────────────────
# Raw & processed datasets (too large for Git — use DVC or Git LFS)
projects/*/data/raw/*
projects/*/data/processed/*
projects/*/*/data/raw/*
projects/*/*/data/processed/*
resources/datasets/*

# Common dataset formats
*.csv
*.tsv
*.json
*.jsonl
*.parquet
*.feather
*.arrow
*.avro
*.hdf5
*.h5
*.pkl
*.pickle

# Keep .gitkeep placeholders so empty folders are tracked
!**/.gitkeep

# ── Model Files ──────────────────────────────────────────────
# Trained models are large — store with Git LFS or cloud storage
shared/models/checkpoints/*
shared/models/final/*
*.pt
*.pth
*.bin
*.ckpt
*.safetensors
*.onnx
*.pb
*.h5
*.keras
*.joblib

# HuggingFace cached models
~/.cache/huggingface/
.cache/huggingface/

# ── NLP Library Caches ───────────────────────────────────────
# NLTK downloaded corpora
nltk_data/

# SpaCy models
en_core_web*/
*.tar.gz

# Gensim word vectors
*.vec
*.bin.gz
*.kv

# Transformers / HuggingFace
transformers_cache/
hf_cache/

# FastText models
*.ftz
*.bin

# ── Experiment Tracking ──────────────────────────────────────
# MLflow
mlruns/
mlartifacts/

# Weights & Biases
wandb/

# TensorBoard logs
runs/
logs/
tensorboard_logs/
events.out.tfevents.*

# Optuna
optuna_studies/
*.db

# ── Outputs ──────────────────────────────────────────────────
projects/*/outputs/*
projects/*/*/outputs/*
!projects/*/outputs/.gitkeep
!projects/*/*/outputs/.gitkeep

# Common output formats (keep structure, ignore large files)
*.png
*.jpg
*.jpeg
*.svg
*.pdf
*.html
*.xlsx
*.zip

# ── Vector Stores & Embeddings ───────────────────────────────
# FAISS indexes
*.faiss
*.index

# ChromaDB
chroma_db/
chromadb/

# Pinecone / Weaviate local data
vector_store/

